<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
>
    <Page
        id="_IDGenPage"
        title="Flight Customers"
    >
        <content>
            <Panel
                id="_IDGenPanel"
                headerText="New Customer"
                expandable="true"
                expanded="true"
            >
                <content>
                    <f:SimpleForm
                        id="_IDGenSimpleForm"
                        layout="ColumnLayout"
                        editable="true"
                    >
                        <f:toolbar>
                            <Toolbar id="_IDGenToolbar">
                                <content>
                                    <ToolbarSpacer id="_IDGenToolbarSpacer" />
                                    <Button
                                        id="_IDGenButton"
                                        icon="sap-icon://create"
                                        text="Create Customer"
                                    />
                                </content>
                            </Toolbar>
                        </f:toolbar>
                        <f:content>
                            <core:Title
                                id="_IDGenTitle1"
                                text="General Data"
                            />
                            <Label
                                id="_IDGenLabel"
                                text="Form"
                            />
                            <Input
                                id="_IDGenInput"
                                value=""
                            />
                            <Label
                                id="_IDGenLabel1"
                                text="Customer Name"
                            />
                            <Input
                                id="_IDGenInput1"
                                value=""
                            />
                            <Label
                                id="_IDGenLabel2"
                                text="Discount"
                            />
                            <Input
                                id="_IDGenInput2"
                                value=""
                            />
                            <core:Title
                                id="_IDGenTitle2"
                                text="Address Data"
                            />
                            <Label
                                id="_IDGenLabel3"
                                text="Street"
                            />
                            <Input
                                id="_IDGenInput3"
                                value=""
                            />
                            <Label
                                id="_IDGenLabel4"
                                text="Post Code"
                            />
                            <Input
                                id="_IDGenInput4"
                                value=""
                            />
                            <Label
                                id="_IDGenLabel5"
                                text="City"
                            />
                            <Input
                                id="_IDGenInput5"
                                value=""
                            />
                            <Label
                                id="_IDGenLabel6"
                                text="Country"
                            />
                            <Input
                                id="_IDGenInput6"
                                value=""
                            />

                            <core:Title
                                id="_IDGenTitle3"
                                text="Contact Data"
                            />
                            <Label
                                id="_IDGenLabel7"
                                text="Email"
                            />

                            <Input
                                id="_IDGenInput7"
                                value=""
                            />
                            <Label
                                id="_IDGenLabel8"
                                text="Telephone"
                            />
                            <Input
                                id="_IDGenInput8"
                                value=""
                            />
                        </f:content>
                    </f:SimpleForm>
                </content>
            </Panel>
        </content>
    </Page>
</mvc:View>
